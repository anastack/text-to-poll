BOT_TOKEN=put-your-telegram-bot-token-here

# Optional default channel. You can also set or replace it in Telegram with /channel.
# Examples: -1001234567890 or @your_public_channel
TARGET_CHANNEL_ID=

# Optional safety: allow only one admin user to create posts (their numeric Telegram user_id)
ADMIN_USER_ID=

# How long (seconds) a previously sent photo can be attached to the next text question.
PHOTO_TTL_SECONDS=600

# Poll settings
POLL_ANONYMOUS=0
POLL_MULTIPLE_ANSWERS=0
